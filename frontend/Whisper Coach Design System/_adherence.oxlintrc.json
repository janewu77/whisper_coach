{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/chat/**",
              "components/core/**",
              "components/forms/**",
              "components/navigation/**",
              "components/pitch/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|style|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, dot, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|neutral|danger)$/]",
        "message": "<Badge> tone must be one of 'brand' | 'neutral' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|icon|iconRight|disabled|onClick|type|style|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, icon, iconRight, disabled, onClick, type, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|subtle|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'subtle' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tinted|sunken|padding|onClick|style|className|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tinted, sunken, padding, onClick, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|from|time|lead|children|style|className|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: role, from, time, lead, children, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:assistant|user)$/]",
        "message": "<ChatBubble> role must be one of 'assistant' | 'user'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|icon|onClick|style|className|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, selected, icon, onClick, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|round|recording|disabled|onClick|label|style|className|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, variant, size, round, recording, disabled, onClick, label, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|neutral|ghost)$/]",
        "message": "<IconButton> variant must be one of 'solid' | 'neutral' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|multiline|rows|style|className|containerStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, multiline, rows, style, className, containerStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pitch'] > JSXAttribute > JSXIdentifier[name!=/^(?:players|selectedId|onSelectPlayer|height|aiBadge|dotSize|children|style|className|key|ref|className|style|children)$/]",
        "message": "<Pitch> doesn't accept that prop. Declared props: players, selectedId, onSelectPlayer, height, aiBadge, dotSize, children, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlayerDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|pos|x|y|size|selected|onClick|style|className|key|ref|className|style|children)$/]",
        "message": "<PlayerDot> doesn't accept that prop. Declared props: name, pos, x, y, size, selected, onClick, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|value|onChange|style|className|key|ref|className|style|children)$/]",
        "message": "<TabBar> doesn't accept that prop. Declared props: items, value, onChange, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|icon|style|className|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, tone, icon, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|amber|red|neutral|inverse)$/]",
        "message": "<Tag> tone must be one of 'green' | 'amber' | 'red' | 'neutral' | 'inverse'."
      },
      {
        "selector": "JSXOpeningElement[name.name='UploadZone'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|count|title|hint|onClick|style|className|key|ref|className|style|children)$/]",
        "message": "<UploadZone> doesn't accept that prop. Declared props: status, count, title, hint, onClick, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='UploadZone'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:idle|processing|done)$/]",
        "message": "<UploadZone> status must be one of 'idle' | 'processing' | 'done'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
