# Copy to .env and fill in. Required for the AI endpoints.
OPENAI_API_KEY=sk-...

# Database. SQLite by default; for Postgres use the psycopg driver:
# DB_URL=postgresql+psycopg://docker:docker@localhost:5432/whisper_coach
# DB_URL=sqlite:///./wc.db

# Optional override (default shown)
# LLM_MODEL=openai-chat:gpt-4o

# ── Auth0 (optional) ──────────────────────────────────────────────────────
# Bearer-token auth. Set BOTH to enforce login on every /api route; leave them
# blank to run the API open (the default — no auth required).
#   AUTH0_DOMAIN   : your tenant, no scheme (e.g. your-tenant.eu.auth0.com)
#   AUTH0_AUDIENCE : the Auth0 API "Identifier" — must match the Flutter app's
#                    AUTH0_AUDIENCE so the access token is accepted.
# AUTH0_DOMAIN=your-tenant.eu.auth0.com
# AUTH0_AUDIENCE=https://whisper-coach.dacheng.dev/api
