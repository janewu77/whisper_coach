# Copy to .env and fill in. Required for the AI endpoints.
OPENAI_API_KEY=sk-...

# Database. SQLite by default; for Postgres use the psycopg driver:
# DB_URL=postgresql+psycopg://docker:docker@localhost:5432/whisper_coach
# DB_URL=sqlite:///./wc.db

# Optional override (default shown)
# LLM_MODEL=openai:gpt-4o
